---
const { headline, subheadline, phone, email, address, formId } = Astro.props.node;
---
<section id="contact" class="section" style="background: var(--color-surface);">
  <div class="container">
    <div style="text-align: center; margin-bottom: var(--spacing-3xl);">
      <h2 style="font-size: var(--font-size-3xl); font-weight: 700; color: var(--color-text); margin-bottom: var(--spacing-sm);">
        {headline}
      </h2>
      {subheadline && (
        <p style="font-size: var(--font-size-lg); color: var(--color-muted);">
          {subheadline}
        </p>
      )}
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-3xl); max-width: 960px; margin: 0 auto;">
      <div style="display: flex; flex-direction: column; gap: var(--spacing-xl);">
        {phone && (
          <div>
            <h4 style="font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text); margin-bottom: var(--spacing-xs);">Phone</h4>
            <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} style="font-size: var(--font-size-base); color: var(--color-primary);">{phone}</a>
          </div>
        )}
        {email && (
          <div>
            <h4 style="font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text); margin-bottom: var(--spacing-xs);">Email</h4>
            <a href={`mailto:${email}`} style="font-size: var(--font-size-base); color: var(--color-primary);">{email}</a>
          </div>
        )}
        {address && (
          <div>
            <h4 style="font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text); margin-bottom: var(--spacing-xs);">Address</h4>
            <p style="font-size: var(--font-size-base); color: var(--color-muted);">{address}</p>
          </div>
        )}
      </div>
      <div>
        <form style="display: flex; flex-direction: column; gap: var(--spacing-md);" data-emdash-form={formId}>
          <input type="text" name="name" placeholder="Your Name" required
            style="padding: var(--spacing-sm) var(--spacing-md); border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: var(--font-size-base); background: var(--color-bg); color: var(--color-text);" />
          <input type="email" name="email" placeholder="Email Address" required
            style="padding: var(--spacing-sm) var(--spacing-md); border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: var(--font-size-base); background: var(--color-bg); color: var(--color-text);" />
          <input type="tel" name="phone" placeholder="Phone Number"
            style="padding: var(--spacing-sm) var(--spacing-md); border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: var(--font-size-base); background: var(--color-bg); color: var(--color-text);" />
          <textarea name="message" placeholder="Your Message" rows="4" required
            style="padding: var(--spacing-sm) var(--spacing-md); border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: var(--font-size-base); background: var(--color-bg); color: var(--color-text); resize: vertical;"></textarea>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    section > div > div:last-child { grid-template-columns: 1fr !important; }
  }
</style>
