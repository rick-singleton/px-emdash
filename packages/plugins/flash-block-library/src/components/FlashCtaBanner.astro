---
const { headline, subheadline, cta } = Astro.props.node;
---
<section id="cta" class="section" style="background: linear-gradient(135deg, var(--color-primary-dark), var(--color-accent)); color: white; text-align: center;">
  <div class="container" style="max-width: 720px;">
    <h2 style="font-size: var(--font-size-3xl); font-weight: 700; margin-bottom: var(--spacing-sm);">
      {headline}
    </h2>
    {subheadline && (
      <p style="font-size: var(--font-size-lg); opacity: 0.9; margin-bottom: var(--spacing-xl);">
        {subheadline}
      </p>
    )}
    {cta && (
      <a href={cta.url} style="display: inline-flex; align-items: center; justify-content: center; padding: var(--spacing-md) var(--spacing-xl); background: white; color: var(--color-primary-dark); font-weight: 600; font-size: var(--font-size-base); border-radius: var(--radius); transition: transform var(--transition-fast), box-shadow var(--transition-fast);">
        {cta.label}
      </a>
    )}
  </div>
</section>
