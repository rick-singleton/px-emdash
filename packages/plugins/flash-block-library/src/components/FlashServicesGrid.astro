---
const { headline, subheadline, services } = Astro.props.node;
---
<section id="services" class="section">
  <div class="container">
    <div style="text-align: center; margin-bottom: var(--spacing-3xl);">
      <h2 style="font-size: var(--font-size-3xl); font-weight: 700; color: var(--color-text); margin-bottom: var(--spacing-sm);">
        {headline}
      </h2>
      {subheadline && (
        <p style="font-size: var(--font-size-lg); color: var(--color-muted); max-width: 600px; margin: 0 auto;">
          {subheadline}
        </p>
      )}
    </div>
    {services && (
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--spacing-xl);">
        {services.map((service: { icon?: string; title: string; description: string }) => (
          <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--spacing-xl); transition: box-shadow var(--transition-base);">
            {service.icon && (
              <div style="width: 48px; height: 48px; border-radius: var(--radius); background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); display: flex; align-items: center; justify-content: center; margin-bottom: var(--spacing-md); color: white; font-size: var(--font-size-xl);">
                <i class={`ph ph-${service.icon}`}></i>
              </div>
            )}
            <h3 style="font-size: var(--font-size-xl); font-weight: 600; color: var(--color-text); margin-bottom: var(--spacing-sm);">
              {service.title}
            </h3>
            <p style="font-size: var(--font-size-base); color: var(--color-muted); line-height: 1.6;">
              {service.description}
            </p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
