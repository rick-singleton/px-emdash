---
import Base from "../layouts/Base.astro";
---
<Base title="Page Not Found">
	<div class="not-found">
		<h1>404</h1>
		<p>This page doesn't exist.</p>
		<a href="/" class="btn btn-primary">Go Home</a>
	</div>
</Base>

<style>
	.not-found {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
	}
	.not-found h1 { font-size: var(--font-size-6xl); color: var(--color-muted); margin-bottom: var(--spacing-md); }
	.not-found p { color: var(--color-muted); margin-bottom: var(--spacing-xl); }
</style>
