{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "emdash-SLUG",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "emdash-SLUG",
			// Replace with real database_id from cf-provision.d1
			"database_id": "LOCAL"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "emdash-SLUG"
		}
	]
}
